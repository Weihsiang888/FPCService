@page "/MachineSetting"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject UIService UIService

<MachineSetting></MachineSetting>

@code {
    private void GetActionCallback(RequestResult res)
    {
        UIService.ShowToast(res);
