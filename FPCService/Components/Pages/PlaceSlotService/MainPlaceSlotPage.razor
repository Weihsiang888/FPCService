@page "/placeslot/main"
@rendermode InteractiveServer
@using FPCService.Data
@using FPCService.Services.Place
@using FPCService.Services
@inject PlaceSlotService PlaceSlotService
@inject DataChangeNotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>場域插槽主檔管理</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddPopup">新增場域插槽</button>
</div>

<DxGrid Data="@placeSlots"
        @ref="grid"
        KeyFieldName="PlaceSlotUid"
        PageSize="20"
        ShowFilterRow="true"
        ShowPager="true">
    <Columns>
        <DxGridDataColumn FieldName="PlaceSlotUid" Caption="插槽編號" Width="120px" />
        <DxGridDataColumn FieldName="PlaceUid" Caption="場域編號" Width="120px" />
        <DxGridDataColumn FieldName="PlaceSlotPoint" Caption="插槽點位" Width="100px" />
        <DxGridDataColumn FieldName="PlaceSlotStatus" Caption="插槽狀態" Width="100px" />
        <DxGridDataColumn FieldName="Floor" Caption="樓層" Width="80px" />
        <DxGridDataColumn FieldName="TaskUid" Caption="任務編號" Width="120px" />
        <DxGridCommandColumn Width="150px">
            <HeaderTemplate>操作</HeaderTemplate>
            <CellDisplayTemplate>
                <button class="btn btn-sm btn-info" @onclick="@(() => ShowEditPopup((context.DataItem as MainPlaceSlot)!))">編輯</button>
                <button class="btn btn-sm btn-danger" @onclick="@(() => DeletePlaceSlot((context.DataItem as MainPlaceSlot)!.PlaceSlotUid))">刪除</button>
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>
</DxGrid>

@if (isPopupVisible)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@popupTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => isPopupVisible = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">插槽編號</label>
                        <input type="text" class="form-control" @bind="editModel.PlaceSlotUid" disabled="@isEditMode" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">場域編號</label>
                        <input type="text" class="form-control" @bind="editModel.PlaceUid" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">插槽點位</label>
                        <input type="number" class="form-control" @bind="editModel.PlaceSlotPoint" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">插槽狀態</label>
                        <input type="text" class="form-control" @bind="editModel.PlaceSlotStatus" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">樓層</label>
                        <input type="number" class="form-control" @bind="editModel.Floor" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">任務編號</label>
                        <input type="text" class="form-control" @bind="editModel.TaskUid" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => isPopupVisible = false">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SavePlaceSlot">儲存</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private IGrid? grid;
    private List<MainPlaceSlot> placeSlots = new();
    private bool isPopupVisible = false;
    private bool isEditMode = false;
    private string popupTitle = "";
    private MainPlaceSlot editModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        NotificationService.MainPlaceSlotChanged += OnDataChanged;
    }

    private async Task LoadData()
    {
        placeSlots = await PlaceSlotService.GetMainPlaceSlotAsync();
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationService.MainPlaceSlotChanged -= OnDataChanged;
    }

    private void ShowAddPopup()
    {
        isEditMode = false;
        popupTitle = "新增場域插槽";
        editModel = new MainPlaceSlot
        {
            Floor = 1,
            PlaceSlotPoint = 0,
            PlaceSlotUid = "",
            PlaceUid = "",
            PlaceSlotStatus = "",
            TaskUid = ""
        };
        isPopupVisible = true;
    }

    private void ShowEditPopup(MainPlaceSlot placeSlot)
    {
        isEditMode = true;
        popupTitle = "編輯場域插槽";
        editModel = new MainPlaceSlot
        {
            PlaceSlotUid = placeSlot.PlaceSlotUid,
            PlaceUid = placeSlot.PlaceUid,
            PlaceSlotPoint = placeSlot.PlaceSlotPoint,
            PlaceSlotStatus = placeSlot.PlaceSlotStatus,
            Floor = placeSlot.Floor,
            TaskUid = placeSlot.TaskUid
        };
        isPopupVisible = true;
    }

    private async Task SavePlaceSlot()
    {
        bool success;
        if (isEditMode)
        {
            success = await PlaceSlotService.UpdateMainPlaceSlotAsync(editModel);
        }
        else
        {
            success = await PlaceSlotService.InsertMainPlaceSlotAsync(editModel);
        }

        if (success)
        {
            isPopupVisible = false;
            // 不需要手動呼叫 LoadData，通知機制會自動觸發
        }
    }

    private async Task DeletePlaceSlot(string uid)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"確定要刪除場域插槽 {uid} 嗎?"))
        {
            await PlaceSlotService.DeleteMainPlaceSlotAsync(uid);
            // 不需要手動呼叫 LoadData，通知機制會自動觸發
        }
    }
}
