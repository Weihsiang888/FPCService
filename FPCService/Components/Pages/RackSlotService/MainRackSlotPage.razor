@page "/rackslot/main"
@rendermode InteractiveServer
@using FPCService.Data
@using FPCService.Services.StorageRack
@using FPCService.Services
@inject RackSlotService RackSlotService
@inject DataChangeNotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>儲存架插槽主檔管理</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddPopup">新增儲存架插槽</button>
</div>

<DxGrid Data="@rackSlots"
        @ref="grid"
        KeyFieldName="RackSlotUid"
        PageSize="20"
        ShowFilterRow="true"
        ShowPager="true">
    <Columns>
        <DxGridDataColumn FieldName="RackSlotUid" Caption="插槽編號" Width="150px" />
        <DxGridDataColumn FieldName="StorageRackUid" Caption="儲存架編號" Width="150px" />
        <DxGridDataColumn FieldName="RackSlotPoint" Caption="插槽點位" Width="120px" />
        <DxGridDataColumn FieldName="RackSlotStatus" Caption="插槽狀態" Width="120px" />
        <DxGridDataColumn FieldName="YarnSpoolType" Caption="紗筒類型" Width="120px" />
        <DxGridDataColumn FieldName="Floor" Caption="樓層" Width="80px" />
        <DxGridDataColumn FieldName="TaskUid" Caption="任務編號" Width="120px" />
        <DxGridCommandColumn Width="150px">
            <HeaderTemplate>操作</HeaderTemplate>
            <CellDisplayTemplate>
                <button class="btn btn-sm btn-info" @onclick="@(() => ShowEditPopup((context.DataItem as MainRackSlot)!))">編輯</button>
                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteRackSlot((context.DataItem as MainRackSlot)!.RackSlotUid))">刪除</button>
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>
</DxGrid>

@if (isPopupVisible)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@popupTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => isPopupVisible = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽編號</label>
                            <input class="form-control" @bind="editModel.RackSlotUid" readonly="@isEditMode" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">儲存架編號</label>
                            <input class="form-control" @bind="editModel.StorageRackUid" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽點位</label>
                            <input type="number" class="form-control" @bind="editModel.RackSlotPoint" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽狀態</label>
                            <input class="form-control" @bind="editModel.RackSlotStatus" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">紗筒類型</label>
                            <input class="form-control" @bind="editModel.YarnSpoolType" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">樓層</label>
                            <input type="number" class="form-control" @bind="editModel.Floor" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">任務編號</label>
                            <input class="form-control" @bind="editModel.TaskUid" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => isPopupVisible = false">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveRackSlot">保存</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<MainRackSlot> rackSlots = new();
    private IGrid? grid;
    private bool isPopupVisible = false;
    private bool isEditMode = false;
    private string popupTitle = "";
    private MainRackSlot editModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        NotificationService.MainRackSlotChanged += OnDataChanged;
    }

    private async Task LoadData()
    {
        rackSlots = await RackSlotService.GetMainRackSlotAsync();
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationService.MainRackSlotChanged -= OnDataChanged;
    }

    private void ShowAddPopup()
    {
        isEditMode = false;
        popupTitle = "新增儲存架插槽";
        editModel = new MainRackSlot
        {
            RackSlotUid = "",
            StorageRackUid = "",
            RackSlotPoint = 0,
            RackSlotStatus = "",
            YarnSpoolType = "",
            Floor = 1,
            TaskUid = ""
        };
        isPopupVisible = true;
    }

    private void ShowEditPopup(MainRackSlot slot)
    {
        isEditMode = true;
        popupTitle = "編輯儲存架插槽";
        editModel = new MainRackSlot
        {
            RackSlotUid = slot.RackSlotUid,
            StorageRackUid = slot.StorageRackUid,
            RackSlotPoint = slot.RackSlotPoint,
            RackSlotStatus = slot.RackSlotStatus,
            YarnSpoolType = slot.YarnSpoolType,
            Floor = slot.Floor,
            TaskUid = slot.TaskUid
        };
        isPopupVisible = true;
    }

    private async Task SaveRackSlot()
    {
        try
        {
            if (isEditMode)
            {
                await RackSlotService.UpdateMainRackSlotAsync(editModel);
            }
            else
            {
                await RackSlotService.InsertMainRackSlotAsync(editModel);
            }
            isPopupVisible = false;
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"保存失敗: {ex.Message}");
        }
    }

    private async Task DeleteRackSlot(string rackSlotUid)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"確定要刪除儲存架插槽 {rackSlotUid} 嗎？");
        if (confirmed)
        {
            try
            {
                await RackSlotService.DeleteMainRackSlotAsync(rackSlotUid);
                await LoadData();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"刪除失敗: {ex.Message}");
            }
        }
    }
}
