@page "/packaging/main"
@rendermode InteractiveServer
@using FPCService.Data
@using FPCService.Services.Packaging
@using FPCService.Services
@inject PackagingService PackagingService
@inject DataChangeNotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>包裝主檔管理</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddPopup">新增包裝</button>
</div>

<DxGrid Data="@packagings"
        @ref="grid"
        KeyFieldName="PackagingUid"
        PageSize="20"
        ShowFilterRow="true"
        ShowPager="true">
    <Columns>
        <DxGridDataColumn FieldName="PackagingUid" Caption="包裝編號" Width="150px" />
        <DxGridDataColumn FieldName="PackagingPoint" Caption="包裝點位" Width="120px" />
        <DxGridDataColumn FieldName="Floor" Caption="樓層" Width="100px" />
        <DxGridDataColumn FieldName="TaskUid" Caption="任務編號" Width="150px" />
        <DxGridDataColumn FieldName="ProcessTime" Caption="處理時間" Width="150px" DisplayFormat="yyyy-MM-dd HH:mm:ss" />
        <DxGridCommandColumn Width="150px">
            <HeaderTemplate>操作</HeaderTemplate>
            <CellDisplayTemplate>
                <button class="btn btn-sm btn-info" @onclick="@(() => ShowEditPopup((context.DataItem as MainPackaging)!))">編輯</button>
                <button class="btn btn-sm btn-danger" @onclick="@(() => DeletePackaging((context.DataItem as MainPackaging)!.PackagingUid))">刪除</button>
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>
</DxGrid>

@if (isPopupVisible)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@popupTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => isPopupVisible = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">包裝編號</label>
                        <input type="text" class="form-control" @bind="editModel.PackagingUid" disabled="@isEditMode" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">包裝點位</label>
                        <input type="number" class="form-control" @bind="editModel.PackagingPoint" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">樓層</label>
                        <input type="number" class="form-control" @bind="editModel.Floor" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">任務編號</label>
                        <input type="text" class="form-control" @bind="editModel.TaskUid" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => isPopupVisible = false">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SavePackaging">儲存</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private IGrid? grid;
    private List<MainPackaging> packagings = new();
    private bool isPopupVisible = false;
    private bool isEditMode = false;
    private string popupTitle = "";
    private MainPackaging editModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        NotificationService.MainPackagingChanged += OnDataChanged;
    }

    private async Task LoadData()
    {
        packagings = await PackagingService.GetMainPackagingAsync();
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationService.MainPackagingChanged -= OnDataChanged;
    }

    private void ShowAddPopup()
    {
        isEditMode = false;
        popupTitle = "新增包裝";
        editModel = new MainPackaging
        {
            ProcessTime = DateTime.Now,
            Floor = 1,
            PackagingPoint = 0,
            TaskUid = "",
            PackagingUid = ""
        };
        isPopupVisible = true;
    }

    private void ShowEditPopup(MainPackaging packaging)
    {
        isEditMode = true;
        popupTitle = "編輯包裝";
        editModel = new MainPackaging
        {
            PackagingUid = packaging.PackagingUid,
            PackagingPoint = packaging.PackagingPoint,
            Floor = packaging.Floor,
            TaskUid = packaging.TaskUid,
            ProcessTime = packaging.ProcessTime
        };
        isPopupVisible = true;
    }

    private async Task SavePackaging()
    {
        editModel.ProcessTime = DateTime.Now;

        bool success;
        if (isEditMode)
        {
            success = await PackagingService.UpdateMainPackagingAsync(editModel);
        }
        else
        {
            success = await PackagingService.InsertMainPackagingAsync(editModel);
        }

        if (success)
        {
            isPopupVisible = false;
            // 不需要手動呼叫 LoadData，通知機制會自動觸發
        }
    }

    private async Task DeletePackaging(string uid)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"確定要刪除包裝 {uid} 嗎?"))
        {
            await PackagingService.DeleteMainPackagingAsync(uid);
            // 不需要手動呼叫 LoadData，通知機制會自動觸發
        }
    }
}
