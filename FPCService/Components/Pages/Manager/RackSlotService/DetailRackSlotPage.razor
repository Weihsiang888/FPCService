@page "/rackslot/detail"
@rendermode InteractiveServer
@using FPCService.Data
@using FPCService.Services.StorageRack
@using FPCService.Services
@inject RackSlotService RackSlotService
@inject DataChangeNotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IDisposable

<h3>儲存架插槽事件明細</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddPopup">新增事件明細</button>
</div>

<DxGrid Data="@details"
        @ref="grid"
        KeyFieldName="UID"
        PageSize="20"
        ShowFilterRow="true"
        ShowPager="true">
    <Columns>
        <DxGridDataColumn FieldName="UID" Caption="序號" Width="80px" />
        <DxGridDataColumn FieldName="RackSlotUid" Caption="插槽編號" Width="120px" />
        <DxGridDataColumn FieldName="StorageRackUid" Caption="儲存架編號" Width="150px" />
        <DxGridDataColumn FieldName="RackSlotPoint" Caption="插槽點位" Width="100px" />
        <DxGridDataColumn FieldName="RackSlotStatus" Caption="插槽狀態" Width="100px" />
        <DxGridDataColumn FieldName="YarnSpoolType" Caption="紗筒類型" Width="100px" />
        <DxGridDataColumn FieldName="Floor" Caption="樓層" Width="80px" />
        <DxGridDataColumn FieldName="TaskUid" Caption="任務編號" Width="120px" />
        <DxGridDataColumn FieldName="OccurrenceTime" Caption="發生時間" Width="150px" />
        <DxGridCommandColumn Width="100px">
            <HeaderTemplate>操作</HeaderTemplate>
            <CellDisplayTemplate>
                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteDetail((context.DataItem as DetailRackSlot)!.UID))">刪除</button>
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>
</DxGrid>

@if (isPopupVisible)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@popupTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => isPopupVisible = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽編號</label>
                            <input class="form-control" @bind="editModel.RackSlotUid" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">儲存架編號</label>
                            <input class="form-control" @bind="editModel.StorageRackUid" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽點位</label>
                            <input type="number" class="form-control" @bind="editModel.RackSlotPoint" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">插槽狀態</label>
                            <input class="form-control" @bind="editModel.RackSlotStatus" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">紗筒類型</label>
                            <input class="form-control" @bind="editModel.YarnSpoolType" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">樓層</label>
                            <input type="number" class="form-control" @bind="editModel.Floor" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">任務編號</label>
                            <input class="form-control" @bind="editModel.TaskUid" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">發生時間</label>
                            <input type="datetime-local" class="form-control" @bind="editModel.OccurrenceTime" readonly />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => isPopupVisible = false">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveDetail">保存</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<DetailRackSlot> details = new();
    private IGrid? grid;
    private bool isPopupVisible = false;
    private string popupTitle = "";
    private DetailRackSlot editModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        NotificationService.DetailRackSlotChanged += OnDataChanged;
    }

    private async Task LoadData()
    {
        details = await RackSlotService.GetDetailRackSlotAsync();
    }

    private async void OnDataChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadData();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationService.DetailRackSlotChanged -= OnDataChanged;
    }

    private void ShowAddPopup()
    {
        popupTitle = "新增事件明細";
        editModel = new DetailRackSlot
        {
            UID = 0,
            RackSlotUid = "",
            StorageRackUid = "",
            RackSlotPoint = 0,
            RackSlotStatus = "",
            YarnSpoolType = "",
            Floor = 1,
            TaskUid = "",
            OccurrenceTime = DateTime.Now
        };
        isPopupVisible = true;
    }

    private async Task SaveDetail()
    {
        try
        {
            await RackSlotService.InsertDetailRackSlotAsync(editModel);
            isPopupVisible = false;
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"保存失敗: {ex.Message}");
        }
    }

    private async Task DeleteDetail(int uid)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"確定要刪除事件明細 {uid} 嗎？");
        if (confirmed)
        {
            try
            {
                await RackSlotService.DeleteDetailRackSlotAsync(uid);
                await LoadData();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"刪除失敗: {ex.Message}");
            }
        }
    }
}
