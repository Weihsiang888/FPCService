@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<nav class="horizontal-nav" @onclick="CloseAllDropdowns">
    <ul class="nav-items">
        <li class="nav-item">
            <a href="/" class="nav-link @(IsActive("/") ? "active" : "")">
                Home
            </a>
        </li>
        <li class="nav-item dropdown @(isDropdownOpen_MobileRobot ? "show" : "")">
            <button class="nav-link dropdown-toggle @(IsActiveParent("/mobilerobot") ? "active" : "")" 
                    type="button"
                    @onclick="() => ToggleDropdown(ref isDropdownOpen_MobileRobot)"
                    @onclick:stopPropagation="true">
                移動車管理
            </button>
            <ul class="dropdown-menu @(isDropdownOpen_MobileRobot ? "show" : "")" @onclick:stopPropagation="true">
                <li><a href="/mobilerobot/main" class="dropdown-item @(IsActive("/mobilerobot/main") ? "active" : "")" @onclick="CloseAllDropdowns">主檔管理</a></li>
                <li><a href="/mobilerobot/detail" class="dropdown-item @(IsActive("/mobilerobot/detail") ? "active" : "")" @onclick="CloseAllDropdowns">事件明細</a></li>
                <li><a href="/mobilerobot/log" class="dropdown-item @(IsActive("/mobilerobot/log") ? "active" : "")" @onclick="CloseAllDropdowns">事件紀錄</a></li>
                <li><a href="/mobilerobot/point" class="dropdown-item @(IsActive("/mobilerobot/point") ? "active" : "")" @onclick="CloseAllDropdowns">點位管理</a></li>
                <li><a href="/mobilerobot/queue" class="dropdown-item @(IsActive("/mobilerobot/queue") ? "active" : "")" @onclick="CloseAllDropdowns">任務佇列管理</a></li>
            </ul>
        </li>
        <li class="nav-item dropdown @(isDropdownOpen_Packaging ? "show" : "")">
            <button class="nav-link dropdown-toggle @(IsActiveParent("/packaging") ? "active" : "")" 
                    type="button"
                    @onclick="() => ToggleDropdown(ref isDropdownOpen_Packaging)"
                    @onclick:stopPropagation="true">
                紗卷包裝管理
            </button>
            <ul class="dropdown-menu @(isDropdownOpen_Packaging ? "show" : "")" @onclick:stopPropagation="true">
                <li><a href="/packaging/main" class="dropdown-item @(IsActive("/packaging/main") ? "active" : "")" @onclick="CloseAllDropdowns">主檔管理</a></li>
                <li><a href="/packaging/detail" class="dropdown-item @(IsActive("/packaging/detail") ? "active" : "")" @onclick="CloseAllDropdowns">事件明細</a></li>
                <li><a href="/packaging/log" class="dropdown-item @(IsActive("/packaging/log") ? "active" : "")" @onclick="CloseAllDropdowns">包裝紀錄</a></li>
                <li><a href="/packaging/queue" class="dropdown-item @(IsActive("/packaging/queue") ? "active" : "")" @onclick="CloseAllDropdowns">包裝佇列管理</a></li>
            </ul>
        </li>
    </ul>
</nav>

@code {
    private string? currentLocalPath;
    private bool isDropdownOpen_MobileRobot = false;
    private bool isDropdownOpen_Packaging = false;

    protected override void OnInitialized() {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        CloseAllDropdowns(); // 導航時關閉所有下拉選單
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDropdown(ref bool dropdownState) {
        // 關閉所有其他下拉選單
        isDropdownOpen_MobileRobot = false;
        isDropdownOpen_Packaging = false;

        // 切換當前下拉選單
        dropdownState = !dropdownState;
        StateHasChanged();
    }

    private void CloseAllDropdowns() {
        isDropdownOpen_MobileRobot = false;
        isDropdownOpen_Packaging = false;
        StateHasChanged();
    }

    private bool IsActive(string path) {
        return string.Equals(currentLocalPath, path, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActiveParent(string parentPath) {
        return currentLocalPath?.StartsWith(parentPath + "/", StringComparison.OrdinalIgnoreCase) == true;
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
